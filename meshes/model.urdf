  </joint>
  <link name="turn_table_left_gripper_attachment">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <!-- TODO: The position needs to be improved -->
        <mesh filename="file:///home/martin/nxtbot_workspace/src/omnit_description/meshes/omnit_v2/gripper_original.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>
  <joint name="turn_table_left_gripper_pin_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.10531 -0.0025 0"/>
    <parent link="turn_table_left_gripper_attachment"/>
    <child link="turn_table_left_gripper_pin"/>
  </joint>
  <gazebo reference="turn_table_left_gripper_pin_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <link name="turn_table_left_gripper_pin">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>
  <!-- this joint is the one controlled from gripper pin to top link using a node, do not rename without changing the config-->
  <joint name="turn_table_docking_link_to_turn_table" type="prismatic">
    <origin rpy="0 0 0" xyz="0 0 0.05"/>
    <parent link="turn_table_top_link"/>
    <child link="turn_table_docking_link"/>
    <axis xyz="1 0 0"/>
    <!-- The lower and upper values correspond to the value of the joint if the arms are fully extended -->
    <!-- This is done so that Gazebo has it "fixed" and docking works as you expect in simulation -->
    <!-- These limits do not affect the tf ROS side -->
    <limit effort="0.0" lower="0.617" upper="0.617" velocity="0.0"/>
    <dynamics damping="1000000000000.0" friction="1000000000000.0"/>
  </joint>
  <gazebo reference="turn_table_docking_link_to_turn_table">
    <stopCfm>0.01</stopCfm>
    <stopErp>0.8</stopErp>
    <implicitSpringDamper>true</implicitSpringDamper>
    <springStiffness>1000000000000.0</springStiffness>
  </gazebo>
  <link name="turn_table_docking_link">
    <!-- No visual for this one, as it is in the field of view of the camera -->
    <!--       <visual name="${name}_docking_link_visual">
        <geometry>
          <cylinder length="0.01" radius="0.01" />
        </geometry>
      </visual> -->
    <!-- Do not remove inertial and pose as this does effect the plugin loading this link! -->
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>
  <gazebo>
    <plugin filename="libgazebo_ros_turn_table.so" name="turn_table_plugin">
      <ros>
      </ros>
      <!-- DOCKING PARAMETERS -->
      <cart_docking_link>docking_link</cart_docking_link>
      <turn_table_docking_link>turn_table_docking_link</turn_table_docking_link>
      <turn_table_top_link_joint>turn_table_top_link_joint</turn_table_top_link_joint>
      <turn_table_top_link_joint_lower_limit>-6.28</turn_table_top_link_joint_lower_limit>
      <turn_table_top_link_joint_upper_limit>6.28</turn_table_top_link_joint_upper_limit>
      <!-- Range in meters to trigger attachment between cart and omnit -->
      <cart_attaching_range>0.2</cart_attaching_range>
      <!-- Range in meters to trigger attachment between charger and omnit -->
      <charger_attaching_range>0.05</charger_attaching_range>
      <!-- SIMULATION : worst-case time it takes for robot to rotate and align after attaching/docking with cart (in seconds) -->
      <align_duration>11.0</align_duration>
      <!-- Set if publishing of turn_table_joint required -->
      <publish_turn_table_joint>true</publish_turn_table_joint>
      <!-- Refresh rate of distance checking between carts and omnit -->
      <update_rate>5</update_rate>
      <!-- Set turn_table_joint publish rate -->
      <publish_rate>60</publish_rate>
      <!-- POSITION CONTROLLER (/set_position action server) -->
      <!-- saturating P-control with velocity input-->
      <!-- avoid chatter by choosing freq rate high and max_velocity low-->
      <!-- Set turn_table_joint position control rate -->
      <position_control_rate>20</position_control_rate>
      <!-- Set max velocity for position controller in rad/s -->
      <max_velocity>0.75</max_velocity>
      <reset_cart>false</reset_cart>
      <!-- In seconds, delay to not instantaneously respawn cart -->
      <reset_delay>1.0</reset_delay>
      <dts_version>2</dts_version>
