        <horizontal_fov>1.5184364492350666</horizontal_fov>
        <image>
          <width>1280</width>
          <height>720</height>
          <format>L_INT8</format>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.05</stddev>
        </noise>
      </camera>
      <always_on>0</always_on>
      <update_rate>1</update_rate>
      <visualize>0</visualize>
    </sensor>
    <sensor name="stereo_cameradepth" type="depth">
      <camera name="stereo_camera">
        <horizontal_fov>1.5184364492350666</horizontal_fov>
        <!-- Sim perf: depth resolution was 1280x720; dropped to 848x480
               (native D455 depth resolution) to reduce GPU + pointcloud cost. -->
        <image>
          <width>848</width>
          <height>480</height>
        </image>
        <clip>
          <near>0.1</near>
          <far>100</far>
        </clip>
        <noise>
          <type>gaussian</type>
          <mean>0.0</mean>
          <stddev>0.100</stddev>
        </noise>
      </camera>
      <always_on>1</always_on>
      <!-- Sim perf: was 90; plugin throttles publication to 30 anyway. -->
      <update_rate>30</update_rate>
      <visualize>0</visualize>
    </sensor>
    <sensor name="stereo_cameraimu_gyro" type="imu">
      <always_on>1</always_on>
      <!-- Publish at 100 hz -->
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
              <bias_mean>0.0000075</bias_mean>
              <bias_stddev>0.0000008</bias_stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
              <bias_mean>0.0000075</bias_mean>
              <bias_stddev>0.0000008</bias_stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
              <bias_mean>0.0000075</bias_mean>
              <bias_stddev>0.0000008</bias_stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
              <bias_mean>0.1</bias_mean>
              <bias_stddev>0.001</bias_stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
              <bias_mean>0.1</bias_mean>
              <bias_stddev>0.001</bias_stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
              <bias_mean>0.1</bias_mean>
              <bias_stddev>0.001</bias_stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="stereo_camera_gyro_plugin">
        <ros>
          <remapping>~/out:=stereo_camera/gyro/data_raw</remapping>
        </ros>
        <frame_name>stereo_camera_gyro_optical_frame</frame_name>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
    <sensor name="stereo_cameraimu_accel" type="imu">
      <always_on>1</always_on>
      <!-- Publish at 100 hz -->
      <update_rate>100</update_rate>
      <imu>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
              <bias_mean>0.0000075</bias_mean>
              <bias_stddev>0.0000008</bias_stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
              <bias_mean>0.0000075</bias_mean>
              <bias_stddev>0.0000008</bias_stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>2e-4</stddev>
              <bias_mean>0.0000075</bias_mean>
              <bias_stddev>0.0000008</bias_stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
              <bias_mean>0.1</bias_mean>
              <bias_stddev>0.001</bias_stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
              <bias_mean>0.1</bias_mean>
              <bias_stddev>0.001</bias_stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>1.7e-2</stddev>
              <bias_mean>0.1</bias_mean>
              <bias_stddev>0.001</bias_stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
      <plugin filename="libgazebo_ros_imu_sensor.so" name="stereo_camera_accel_plugin">
        <ros>
          <remapping>~/out:=stereo_camera/accel/data_raw</remapping>
        </ros>
        <frame_name>stereo_camera_accel_optical_frame</frame_name>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
      </plugin>
    </sensor>
  </gazebo>
  <gazebo>
    <plugin filename="librealsense_gazebo_plugin.so" name="stereo_camera_plugin">
      <prefix>stereo_camera</prefix>
      <depthUpdateRate>30.0</depthUpdateRate>
      <colorUpdateRate>30.0</colorUpdateRate>
      <!-- Sim perf: infrared disabled (was 30.0); infra1/infra2 not required. -->
      <infraredUpdateRate>0.0</infraredUpdateRate>
      <depthTopicName>stereo_camera/depth/image_raw</depthTopicName>
      <depthCameraInfoTopicName>stereo_camera/depth/camera_info</depthCameraInfoTopicName>
      <colorTopicName>stereo_camera/color/image_raw</colorTopicName>
      <colorCameraInfoTopicName>stereo_camera/color/camera_info</colorCameraInfoTopicName>
      <!-- IR topic names kept non-empty (advertiseCamera("") throws and breaks depth_pub_
             setup); actual IR renders are suppressed by always_on=0 on the ired sensors. -->
      <infrared1TopicName>stereo_camera/infra1/image_raw</infrared1TopicName>
      <infrared1CameraInfoTopicName>stereo_camera/infra1/camera_info</infrared1CameraInfoTopicName>
      <infrared2TopicName>stereo_camera/infra2/image_raw</infrared2TopicName>
      <infrared2CameraInfoTopicName>stereo_camera/infra2/camera_info</infrared2CameraInfoTopicName>
      <colorOpticalframeName>stereo_camera_color_optical_frame</colorOpticalframeName>
      <depthOpticalframeName>stereo_camera_depth_optical_frame</depthOpticalframeName>
      <infrared1OpticalframeName>stereo_camera_infra1_optical_frame</infrared1OpticalframeName>
      <infrared2OpticalframeName>stereo_camera_infra2_optical_frame</infrared2OpticalframeName>
      <rangeMinDepth>0.2</rangeMinDepth>
      <rangeMaxDepth>10.0</rangeMaxDepth>
      <pointCloud>False</pointCloud>
      <pointCloudTopicName>stereo_camera/depth/color/points</pointCloudTopicName>
      <pointCloudCutoff>0.25</pointCloudCutoff>
      <pointCloudCutoffMax>9.0</pointCloudCutoffMax>
    </plugin>
  </gazebo>
  <gazebo>
    <!-- position controller -->
    <plugin filename="libgazebo_ros_planar_move.so" name="omnit_planar_mover">
      <ros>
        <!-- Add a namespace -->
        <namespace>/</namespace>
        <!-- Remap the default topic -->
        <!-- use odom safe to test simulation safety -->
        <remapping>cmd_vel:=cmd_vel/safe</remapping>
        <!-- use default odom so we don't need to run robot localization as in simulation odom is perfect -->
        <remapping>odom:=odom</remapping>
      </ros>
      <!-- Set control loop update rate -->
      <update_rate>100</update_rate>
      <!-- Set odom publish rate -->
      <publish_rate>60</publish_rate>
      <!-- Set if odom required -->
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <!-- Frame IDs -->
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
      <!-- Set odom covariance -->
      <covariance_x>0.0001</covariance_x>
      <covariance_y>0.0001</covariance_y>
      <covariance_yaw>0.01</covariance_yaw>
    </plugin>
    <!-- battery controller -->
    <plugin filename="libgazebo_ros_battery.so" name="omnit_gz_classic_battery_plugin">
      <ros>
        <!-- Add a namespace -->
        <namespace>/</namespace>
        <!-- Remap the default topic -->
        <remapping>battery_state:=mcu_system/power/battery_state/data</remapping>
      </ros>
      <battery_name>linear_battery</battery_name>
      <!-- In V -->
      <voltage>48</voltage>
      <!-- In percents -->
      <initial_charge>0.95</initial_charge>
      <!-- In Ah -->
      <capacity>42.0</capacity>
      <!-- In W -->
      <charging_power>3000</charging_power>
      <!-- In W -->
      <static_power_load>144</static_power_load>
      <!-- In W/(m/s) -->
      <friction_power_loss>144</friction_power_loss>
      <!-- In m -->
      <charging_station_max_distance>0.25</charging_station_max_distance>
      <charger_model_name_search_term>charger</charger_model_name_search_term>
      <!-- Set if publishing of topic required -->
      <publish_state>true</publish_state>
      <!-- Set publish rate publish rate -->
      <publish_rate>1</publish_rate>
    </plugin>
  </gazebo>
  <!-- turn table base box link -->
  <joint name="turn_table_base_to_chassis" type="fixed">
    <parent link="chassis"/>
    <child link="turn_table_base"/>
    <origin rpy="0 0 0" xyz="0 0 0.331"/>
  </joint>
  <link name="turn_table_base">
    <visual>
      <geometry>
        <mesh filename="file:///home/martin/nxtbot_workspace/src/omnit_description/meshes/omnit_v2/turn_table_base.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.3" ixy="0.0" ixz="0.0" iyy="0.6" iyz="0.0" izz="1"/>
    </inertial>
  </link>
  <!-- turn table base and top, with origin in the middle -->
  <joint name="turn_table_top_link_joint" type="continuous">
    <axis xyz="0 0 1"/>
    <limit effort="5" velocity="0.75"/>
    <origin rpy="0 0 0" xyz="0.0 0.0 0.0536"/>
    <parent link="turn_table_base"/>
    <child link="turn_table_top_link"/>
    <dynamics damping="0.7" friction="0.9"/>
  </joint>
  <gazebo reference="turn_table_top_link_joint">
    <stopCfm>0.000010</stopCfm>
    <stopErp>0.2</stopErp>
    <implicitSpringDamper>true</implicitSpringDamper>
  </gazebo>
  <link name="turn_table_top_link">
    <visual>
      <geometry>
        <mesh filename="file:///home/martin/nxtbot_workspace/src/omnit_description/meshes/omnit_v2/turn_table.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <!-- cover collision -->
    <collision>
      <geometry>
        <mesh filename="file:///home/martin/nxtbot_workspace/src/omnit_description/meshes/omnit_v2/turn_table_collision.dae" scale="1 1 1"/>
      </geometry>
      <origin rpy="0 0 0" xyz="0 0 0"/>
    </collision>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.001"/>
      <inertia ixx="0.5" ixy="0.0" ixz="0.0" iyy="0.8" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>
  <joint name="base_to_imu_front_top_insert" type="fixed">
    <parent link="turn_table_base"/>
    <child link="imu_front_top_insert"/>
    <origin rpy="0 0 0" xyz="0.3647 0.0377 0.0"/>
  </joint>
  <link name="imu_front_top_insert"/>
  <joint name="imu_front_top_insert_to_device" type="fixed">
    <parent link="imu_front_top_insert"/>
    <child link="imu_front_top"/>
    <origin rpy="0 3.14 -1.57" xyz="0.0 0.0 0.005"/>
  </joint>
  <link name="imu_front_top"/>
  <!-- It's not possible to mirror a set of joints, only a mass. That's why we need to have a 'y_scale' variable in our case -->
  <!-- to determine if you're adding the left and right joints. Additionally, the rotation direction of the arms is also different, -->
  <!-- and we also need to consider the links. -->
  <joint name="turn_table_right_gripper_joint" type="revolute">
    <origin rpy="0 0 1.291965" xyz="-0.08 -0.275 0.0471"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-1.36" upper="-1.36" velocity="1"/>
    <parent link="turn_table_top_link"/>
    <child link="turn_table_right_gripper_dummy"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>
  <link name="turn_table_right_gripper_dummy">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0.0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>
  <joint name="turn_table_right_gripper_dummy_joint" type="revolute">
    <origin rpy="0 0 -1.291965" xyz="-0.061927 0.21631 0.0"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="1.36" upper="1.36" velocity="1"/>
    <parent link="turn_table_right_gripper_dummy"/>
    <child link="turn_table_right_gripper"/>
    <dynamics damping="0.0" friction="0.0"/>
  </joint>
  <link name="turn_table_right_gripper">
    <visual>
      <origin rpy="0 0 0" xyz="0.397 -0.2035 0"/>
      <geometry>
        <mesh filename="file:///home/martin/nxtbot_workspace/src/omnit_description/meshes/omnit_v2/elbow.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>
  <joint name="turn_table_right_gripper_attachment_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.370 -0.2025 0"/>
    <parent link="turn_table_right_gripper"/>
    <child link="turn_table_right_gripper_attachment"/>
  </joint>
  <link name="turn_table_right_gripper_attachment">
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
