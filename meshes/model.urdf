      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>
  <joint name="turn_table_left_gripper_joint" type="revolute">
    <origin rpy="3.141592653589793 0 -1.291965" xyz="-0.08 0.275 0.0471"/>
    <axis xyz="0 0 1"/>
    <limit effort="100" lower="-1.36" upper="-1.36" velocity="1"/>
    <parent link="turn_table_top_link"/>
    <child link="turn_table_left_gripper_dummy"/>
    <dynamics damping="0.0" friction="0.0"/>
