        <mesh filename="file:///home/martin/nxtbot_workspace/src/omnit_description/meshes/omnit_v2/gripper_original.dae" scale="1 1 1"/>
      </geometry>
    </visual>
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <mass value="0.1"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>
  <joint name="turn_table_right_gripper_pin_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0.10531 -0.0025 0"/>
    <parent link="turn_table_right_gripper_attachment"/>
    <child link="turn_table_right_gripper_pin"/>
  </joint>
  <gazebo reference="turn_table_right_gripper_pin_joint">
    <preserveFixedJoint>true</preserveFixedJoint>
  </gazebo>
  <link name="turn_table_right_gripper_pin">
